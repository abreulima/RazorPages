@page
@model RazorPages.Pages.ProfileModel
@{
    ViewData["Title"] = "Editar Perfil";
    Layout = "_LayoutForm";
}

<form method="post">

    <h1>Editar Perfil</h1>

    <div class="flex justify-between gap-2">
        <label>nome</label>
        <input name="firstName" type="text" value="@Model.FirstName">
    </div>

    <div class="flex justify-between gap-2">
        <label>apelido</label>
        <input name="lastName" type="text" value="@Model.LastName">
    </div>

    <div class="flex justify-between gap-2">
        <label>email</label>
        <input name="email" type="email" value="@Model.Email">
    </div>

    <button type="submit">guardar</button>

    @if (Model.Error)
    {
        <span class="alert">Email já registado.</span>
    }

    <div class="links">
        <span><a href="/Index">Voltar</a></span>
    </div>

</form>
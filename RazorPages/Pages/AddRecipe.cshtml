@page
@model RazorPages.Pages.AddRecipeModel

@{
    ViewData["Title"] = "Registo";
	Layout = "_LayoutForm";
}

<form method="post" class="flex flex-col gap-4">

    <h1>Receita</h1>

    <div class="flex items-center gap-2">
        <label>É um pastel de nata?</label>
        <input onclick="isNatas(this);" type="checkbox" checked>
    </div>

    <div id="content" class="flex flex-col gap-4">

        <div class="flex flex-col gap-1">
            <label>Título</label>
            <input name="Title" type="text" required>
        </div>

        <div class="flex flex-col gap-1">
            <label>Categoria</label>
            <select name="CategoryId" required>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>

        <div class="flex flex-col gap-1">
            <label>Dificuldade</label>
            <select name="DifficultId" required>
                @foreach (var difficult in Model.Difficulties)
                {
                    <option value="@difficult.Id">@difficult.Name</option>
                }
            </select>
        </div>

        <div class="flex flex-col gap-2">
            <label>Ingredientes</label>

            <div id="container" class="flex flex-col gap-2">
                <div id="ingredientForm" class="flex gap-2">

                    <select name="IngredientesInput[0].IngredientId" required>
                        @foreach (var ingredient in Model.AvailableIngredients)
                        {
                            <option value="@ingredient.Id">@ingredient.Name</option>
                        }
                    </select>

                    <input name="IngredientesInput[0].Quantity" type="number" required placeholder="Qtd">

                    <input name="IngredientesInput[0].Unity" type="text" placeholder="Unidade">

                </div>

            </div>
            

            <button onclick="addMoreIngredient(); return false;">
                adicionar mais
            </button>
        </div>

        <div class="flex flex-col gap-1">
            <label>Preparação</label>
            <textarea name="Preparation"
                      required
                      rows="5"
                      class="rounded-sm border-2 bg-yellow-300 px-2 py-1 resize-none"
                      placeholder="Descreva os passos da receita..."></textarea>
        </div>

        <button type="submit">enviar</button>

    </div>


     <div class="links">
        <a href="/Index">Voltar</a>
    </div>


</form>

<script>

	var i = 0;
	var original = document.getElementById('ingredientForm');
    var container = document.getElementById('container');

	function addMoreIngredient() {
		var clone = original.cloneNode(true);
		clone.id = "ingredientForm" + ++i;

		// Cria um name unico para cada input clonado.
		clone.querySelectorAll('input, select').forEach(el => 
		{
			el.name = el.name.replace('[0]', `[${i}]`);
		});

		original.parentNode.appendChild(clone);
	}

	function isNatas(checkbox) {
		var formContent = document.getElementById("content");
		if (checkbox.checked)
			formContent.style.display = "block"
		else
			formContent.style.display = "none";
	}


</script>
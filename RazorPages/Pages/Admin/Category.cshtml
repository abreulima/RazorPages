@page
@model RazorPages.Pages.Admin.CategoryModel

@{
    ViewData["Title"] = "Registo";
	Layout = "_LayoutForm";
}

<form method="post" action="">

	<h1>Novo Categoria</h1>

	<div class="flex justify-between gap-2">
		<label>nome</label>
		<input name="name" type="text">
	</div>

	<button type="submit">enviar</button>

	@if (Model.Error)
	{
		<span class="alert">Categoria já registrado.</span>
	}

	<div class="links">
		<span><a href="/admin">Voltar</a></span>
	</div>

</form>